{
  "name": "parcel-vanilla-starter",
  "private": true,
  "version": "0.0.0",
  "source": "src/index.html",
  "browserslist": "last 10 years, not dead",
  "scripts": {
    "parcel:dev": "parcel src/*.html",
    "parcel:build": "parcel build src/*.html",
