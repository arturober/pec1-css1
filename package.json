    "npm-run-all": "^4.1.5",
    "parcel": "^2.14.0",
    "postcss": "^8.5.8",
    "postcss-import": "^16.1.1",
    "posthtml-include": "^2.0.1",
    "rimraf": "^6.1.3",
    "sharp": "^0.33.5"
  },
  "dependencies": {
    "ol": "^10.8.0"
  },
  "@parcel/resolver-default": {
    "packageExports": true
  }
